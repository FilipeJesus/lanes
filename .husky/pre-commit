#!/bin/sh

echo "🔍 Running pre-commit checks..."

# Compile TypeScript
echo "📦 Compiling TypeScript..."
LANES_NO_INSTALL_IN_HOOKS=1 npm run compile || exit 1

# Run ESLint
echo "🧹 Running ESLint..."
npm run lint || exit 1

# Run tests (use xvfb-run if available for headless environments)
echo "🧪 Running tests..."
if [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
    xvfb-run -a npm run test:hook || exit 1
else
    npm run test:hook || exit 1
fi

# Run web UI tests if web files changed
WEB_CHANGED=$(git diff --cached --name-only -- 'web-ui/' | head -1)
if [ -n "$WEB_CHANGED" ]; then
    echo "🌐 Running web UI unit tests..."
    npm --prefix web-ui test || exit 1

    echo "🌐 Running web UI e2e tests..."
    if [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
        xvfb-run -a npm --prefix web-ui run test:e2e || exit 1
    else
        npm --prefix web-ui run test:e2e || exit 1
    fi
fi

# Rebuild docs.html if any docs source files changed
DOCS_CHANGED=$(git diff --cached --name-only -- 'docs/docs-shell.html' 'docs/sections/' | head -1)
if [ -n "$DOCS_CHANGED" ]; then
    echo "📄 Rebuilding docs.html..."
    npm run build:docs --prefix docs || exit 1
    git add docs/docs.html
fi

echo "✅ All checks passed!"
