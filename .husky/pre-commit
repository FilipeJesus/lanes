#!/bin/sh

echo "🔍 Running pre-commit checks..."

# Compile TypeScript
echo "📦 Compiling TypeScript..."
npm run compile || exit 1

# Run ESLint
echo "🧹 Running ESLint..."
npm run lint || exit 1

# Run tests (use xvfb-run if available for headless environments)
echo "🧪 Running tests..."
if [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
    xvfb-run -a npm run test || exit 1
else
    npm run test || exit 1
fi

# Run web UI tests if web files changed
WEB_CHANGED=$(git diff --cached --name-only -- 'web-ui/' | head -1)
if [ -n "$WEB_CHANGED" ]; then
    echo "🌐 Running web UI unit tests..."
    npm --prefix web-ui test || exit 1

    echo "🌐 Running web UI e2e tests..."
    if [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
        xvfb-run -a npm --prefix web-ui run test:e2e || exit 1
    else
        npm --prefix web-ui run test:e2e || exit 1
    fi
fi

# Run IntelliJ plugin tests if plugin files changed
JB_CHANGED=$(git diff --cached --name-only -- 'jetbrains-ide-plugin/' | head -1)
if [ -n "$JB_CHANGED" ]; then
    echo "🧪 Running JetBrains IDE plugin tests..."
    JAVA17_HOME="${JAVA17_HOME:-/home/linuxbrew/.linuxbrew/Cellar/openjdk@17/17.0.18/libexec}"
    if [ -d "$JAVA17_HOME" ]; then
        (cd jetbrains-ide-plugin && JAVA_HOME="$JAVA17_HOME" ./gradlew test) || exit 1
    else
        echo "⚠️  Skipping JetBrains IDE tests: Java 17 not found at $JAVA17_HOME (set JAVA17_HOME to override)"
    fi
fi

# Rebuild docs.html if any docs source files changed
DOCS_CHANGED=$(git diff --cached --name-only -- 'docs/docs-shell.html' 'docs/sections/' | head -1)
if [ -n "$DOCS_CHANGED" ]; then
    echo "📄 Rebuilding docs.html..."
    npm run build:docs --prefix docs || exit 1
    git add docs/docs.html
fi

echo "✅ All checks passed!"
